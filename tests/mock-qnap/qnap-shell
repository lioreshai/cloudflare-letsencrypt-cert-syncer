#!/bin/bash
#
# Mock QNAP shell for testing cert-push script
# Simulates QNAP SSH + sudo behavior for certificate operations
#

STATE_DIR="/state"

# Parse the command passed via SSH -c
if [[ "$1" == "-c" ]]; then
    CMD="$2"
else
    CMD="$*"
fi

# Log command for debugging
echo "[$(date -Iseconds)] CMD: $CMD" >> /state/command.log

# Handle scp (file transfers)
if [[ "$CMD" =~ ^scp ]]; then
    exec /usr/bin/scp "$@"
fi

# Handle echo for readiness checks
if [[ "$CMD" =~ ^echo.*ready ]]; then
    echo "ready"
    exit 0
fi

# Handle sudo cat for reading certificate (fingerprint check)
# Command: echo 'pass' | sudo -S cat /etc/stunnel/stunnel.pem 2>/dev/null | openssl x509 ...
# We need to execute the full pipe to get the fingerprint output
if [[ "$CMD" =~ sudo.*cat.*/etc/stunnel/stunnel.pem.*openssl ]]; then
    if [[ -f "$STATE_DIR/stunnel.pem" ]]; then
        # Execute the openssl part to get fingerprint
        cat "$STATE_DIR/stunnel.pem" | openssl x509 -noout -fingerprint -sha256 2>/dev/null
    fi
    exit 0
fi

# Handle multi-line sudo operations (certificate installation)
# The command contains multiple lines with sudo cp, chmod, chown, rm
if [[ "$CMD" =~ sudo.*cp.*\.pem ]]; then
    # Find PEM files in home directory and copy to state
    for pem in /home/qnap/*.pem; do
        if [[ -f "$pem" ]]; then
            cp "$pem" "$STATE_DIR/stunnel.pem"
            rm -f "$pem"
        fi
    done
    exit 0
fi

# Handle web server restart
if [[ "$CMD" =~ /etc/init.d/thttpd.sh ]]; then
    echo "Stopping QNAP web server..."
    echo "Starting QNAP web server..."
    exit 0
fi

# Handle rm command for cleanup
if [[ "$CMD" =~ ^rm ]]; then
    eval "$CMD" 2>/dev/null || true
    exit 0
fi

# Unknown command - log and ignore
echo "[MOCK] Unknown command: $CMD" >> /state/unknown.log
