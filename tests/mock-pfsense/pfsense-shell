#!/bin/bash
#
# Mock pfSense shell for testing cert-push script
# Simulates pfSense command responses for certificate operations
#

STATE_DIR="/state"

# Parse the command passed via SSH -c
if [[ "$1" == "-c" ]]; then
    CMD="$2"
else
    CMD="$*"
fi

# Log command for debugging
echo "[$(date -Iseconds)] CMD: $CMD" >> /state/command.log

# Handle scp (file transfers)
if [[ "$CMD" =~ ^scp ]]; then
    exec /usr/bin/scp "$@"
fi

# Handle PHP commands for fingerprint retrieval
if [[ "$CMD" =~ php.*-r.*config_get_path ]]; then
    # Extract domain from the PHP code
    DOMAIN=$(echo "$CMD" | sed -n 's/.*descr.*===.*"\([^"]*\)".*/\1/p')
    CERT_FILE="$STATE_DIR/cert_${DOMAIN}.crt"

    if [[ -f "$CERT_FILE" ]]; then
        # Output the stored certificate (base64 decoded)
        cat "$CERT_FILE"
    fi
    exit 0
fi

# Handle PHP import script execution
if [[ "$CMD" =~ php.*/tmp/import_cert.php ]]; then
    # Extract domain from command
    DOMAIN=$(echo "$CMD" | sed -n "s/.*import_cert.php '\([^']*\)'.*/\1/p")

    # Read the uploaded cert/key files
    if [[ -f "/tmp/cert.crt" ]] && [[ -f "/tmp/cert.key" ]]; then
        # Store the certificate for fingerprint retrieval
        cp /tmp/cert.crt "$STATE_DIR/cert_${DOMAIN}.crt"
        cp /tmp/cert.key "$STATE_DIR/cert_${DOMAIN}.key"

        echo "Creating new certificate entry..."
        echo "Certificate imported successfully. RefID: mock-$(date +%s)"

        # Cleanup
        rm -f /tmp/cert.crt /tmp/cert.key /tmp/import_cert.php
    else
        echo "ERROR: Could not read cert/key files"
        exit 1
    fi
    exit 0
fi

# Handle cat > /tmp/import_cert.php (receiving PHP script)
if [[ "$CMD" =~ cat.*import_cert.php ]]; then
    cat > /tmp/import_cert.php
    exit 0
fi

# Handle webgui restart
if [[ "$CMD" =~ rc.restart_webgui ]]; then
    echo "Restarting webConfigurator..."
    exit 0
fi

# Handle rm command for cleanup
if [[ "$CMD" =~ ^rm ]]; then
    eval "$CMD" 2>/dev/null || true
    exit 0
fi

# Handle echo for readiness checks
if [[ "$CMD" =~ ^echo ]]; then
    echo "${CMD#echo }"
    exit 0
fi

# Unknown command - log and ignore
echo "[MOCK] Unknown command: $CMD" >> /state/unknown.log
